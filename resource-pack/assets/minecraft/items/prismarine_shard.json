{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:custom_model_data",
    "cases": [
      {
        "when": "mag_pistol",
        "model": {
          "type": "minecraft:model",
          "model": "guns:item/mag_pistol"
        }
      },
      {
        "when": "mag_pistol_ext",
        "model": {
          "type": "minecraft:model",
          "model": "guns:item/mag_pistol_ext"
        }
      },
      {
        "when": "mag_rifle",
        "model": {
          "type": "minecraft:model",
          "model": "guns:item/mag_rifle"
        }
      },
      {
        "when": "mag_rifle_drum",
        "model": {
          "type": "minecraft:model",
          "model": "guns:item/mag_rifle_drum"
        }
      },
      {
        "when": "mag_smg",
        "model": {
          "type": "minecraft:model",
          "model": "guns:item/mag_smg"
        }
      },
      {
        "when": "mag_sniper",
        "model": {
          "type": "minecraft:model",
          "model": "guns:item/mag_sniper"
        }
      },
      {
        "when": "shells_shotgun",
        "model": {
          "type": "minecraft:model",
          "model": "guns:item/shells_shotgun"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/prismarine_shard"
    }
  }
}